# Environment Variables Template
# Copy this file to .env and fill in your actual values

NODE_ENV=production

# LLM API Keys (Fallback architecture: Groq → Gemini → DeepSeek)
GROQ_API_KEY=your_groq_api_key_here
LLM_API_KEY=your_gemini_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# System Prompt for AI Personality
SYSTEM_PROMPT=You are Mohammed Saleh's AI Assistant. You embody his expertise in AI, software engineering, and intelligent systems. You are professional, knowledgeable, and helpful.
